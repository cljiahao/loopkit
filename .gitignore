# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# mutation testing (stryker)
/.stryker-tmp
/reports
/stryker-out.txt

# playwright (e2e)
/test-results
/playwright-report
/playwright/.cache

# brainstorming visual companion (local mockups, not committed)
/.superpowers

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# agent framework symlink — per-machine convenience, never commit. A tracked
# symlink breaks Windows CI runners ("Unable to load symbolic/hard linked
# file"). Recreate locally: ln -s .claude .agents
.agents

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# per-developer skill-usage telemetry, not shared state
.claude/skill-usage.log

# env files (can opt-in for committing if needed)
.env
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# git worktrees (local scratch) — .worktrees/ is the manual-fallback convention,
# .claude/worktrees/ is what the native EnterWorktree tool actually creates
.worktrees/
.claude/worktrees/
